{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "installCommand": "npm install",
  "env": {
    "DATABASE_URL": "file:/tmp/dev.db"
  },
  "functions": {
    "src/app/api/**/*.ts": {
      "includeFiles": "prisma/dev.db"
    }
  }
}
