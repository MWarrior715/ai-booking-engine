# AI Booking Engine — configuración de ejemplo.
# Copia a .env y ajusta. Nunca commitees .env real.

# Base de datos local (SQLite para el PoC).
# El schema de Prisma está preparado para PostgreSQL: cambia provider y URL para producción.
DATABASE_URL="file:./prisma/dev.db"

# Motor de IA Local/Cloud (OpenAI-compatible API).
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local-dev-key
LLM_MODEL=glm-5.2:cloud

# Puerto del servidor (Next.js + Socket.io custom server).
PORT=3000
