# AI Booking Engine — configuración de ejemplo.
# Copia a .env y ajusta. Nunca commitees .env real.

# Base de datos. Usa PostgreSQL en Vercel (Neon) para el deploy público.
# En local puedes seguir usando SQLite cambiando el provider en schema.prisma.
DATABASE_URL="postgresql://user:pass@localhost:5432/booking_engine"

# Motor de IA Local/Cloud (OpenAI-compatible API).
# Para la demo pública sin exponer Ollama local, déjalo vacío y el chat usa fallback local.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=local-dev-key
LLM_MODEL=glm-5.2:cloud

# Puerto del servidor (Next.js + Socket.io custom server, solo local).
PORT=3000
